<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://example.org/bank_ontology_ru.owl"
         xmlns="http://example.org/bank_ontology_ru.owl#">

<owl:Ontology rdf:about="http://example.org/bank_ontology_ru.owl"/>

<owl:ObjectProperty rdf:about="#владеет_счетом">
  <rdfs:domain rdf:resource="#Клиент"/>
  <rdfs:range rdf:resource="#Счет"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#имеет_кредит">
  <rdfs:domain rdf:resource="#Клиент"/>
  <rdfs:range rdf:resource="#Кредит"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#относится_к_счету">
  <rdfs:domain rdf:resource="#Транзакция"/>
  <rdfs:range rdf:resource="#Счет"/>
</owl:ObjectProperty>

<owl:DatatypeProperty rdf:about="#фио">
  <rdfs:domain rdf:resource="#Клиент"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#дата_рождения">
  <rdfs:domain rdf:resource="#Клиент"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#паспортные_данные">
  <rdfs:domain rdf:resource="#Клиент"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#адрес">
  <rdfs:domain rdf:resource="#Клиент"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#телефон">
  <rdfs:domain rdf:resource="#Клиент"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#email">
  <rdfs:domain rdf:resource="#Клиент"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#номер_счета">
  <rdfs:domain rdf:resource="#Счет"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#тип_счета">
  <rdfs:domain rdf:resource="#Счет"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#валюта">
  <rdfs:domain rdf:resource="#Счет"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#дата_открытия">
  <rdfs:domain rdf:resource="#Счет"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#остаток">
  <rdfs:domain rdf:resource="#Счет"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#дата_транзакции">
  <rdfs:domain rdf:resource="#Транзакция"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#сумма_транзакции">
  <rdfs:domain rdf:resource="#Транзакция"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#тип_транзакции">
  <rdfs:domain rdf:resource="#Транзакция"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#описание">
  <rdfs:domain rdf:resource="#Транзакция"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#сумма_кредита">
  <rdfs:domain rdf:resource="#Кредит"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#процентная_ставка">
  <rdfs:domain rdf:resource="#Кредит"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#срок_в_месяцах">
  <rdfs:domain rdf:resource="#Кредит"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#дата_выдачи">
  <rdfs:domain rdf:resource="#Кредит"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#ежемесячный_платеж">
  <rdfs:domain rdf:resource="#Кредит"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:Class rdf:about="#Клиент">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Счет">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Транзакция">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Кредит">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>


</rdf:RDF>
